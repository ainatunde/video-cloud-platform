{
  "uid": "streaming-overview",
  "title": "Streaming Overview",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "5s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "stream_id",
        "label": "Stream",
        "type": "query",
        "datasource": { "type": "postgres", "uid": "timescaledb" },
        "query": "SELECT DISTINCT stream_id FROM stream_metrics ORDER BY 1",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "allValue": ".*",
        "current": {}
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Active Streams",
      "type": "stat",
      "datasource": { "type": "postgres", "uid": "timescaledb" },
      "targets": [
        {
          "rawSql": "SELECT COUNT(DISTINCT stream_id) AS value FROM stream_metrics WHERE $__timeFilter(time)",
          "format": "table"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 50 }
            ]
          }
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 }
    },
    {
      "id": 2,
      "title": "Total Viewers",
      "type": "stat",
      "datasource": { "type": "postgres", "uid": "timescaledb" },
      "targets": [
        {
          "rawSql": "SELECT SUM(viewer_count) AS value FROM stream_metrics WHERE $__timeFilter(time) AND stream_id = ANY(string_to_array('$stream_id', ','))",
          "format": "table"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          }
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 }
    },
    {
      "id": 3,
      "title": "Avg Bitrate (bps)",
      "type": "timeseries",
      "datasource": { "type": "postgres", "uid": "timescaledb" },
      "targets": [
        {
          "rawSql": "SELECT time_bucket('1m', time) AS time, stream_id, AVG(bitrate) AS avg_bitrate FROM stream_metrics WHERE $__timeFilter(time) GROUP BY 1, 2 ORDER BY 1",
          "format": "time_series"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bps",
          "color": { "mode": "palette-classic" }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 }
    },
    {
      "id": 4,
      "title": "Avg Latency (ms)",
      "type": "timeseries",
      "datasource": { "type": "postgres", "uid": "timescaledb" },
      "targets": [
        {
          "rawSql": "SELECT time_bucket('1m', time) AS time, stream_id, AVG(latency_ms) AS avg_latency FROM stream_metrics WHERE $__timeFilter(time) GROUP BY 1, 2 ORDER BY 1",
          "format": "time_series"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 2000 },
              { "color": "red", "value": 5000 }
            ]
          }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 }
    },
    {
      "id": 5,
      "title": "Avg Buffer Ratio",
      "type": "gauge",
      "datasource": { "type": "postgres", "uid": "timescaledb" },
      "targets": [
        {
          "rawSql": "SELECT AVG(buffer_ratio) AS value FROM stream_metrics WHERE $__timeFilter(time)",
          "format": "table"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.05 },
              { "color": "red", "value": 0.1 }
            ]
          }
        }
      },
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 12 }
    },
    {
      "id": 6,
      "title": "Viewer Count by Geography",
      "type": "geomap",
      "datasource": { "type": "postgres", "uid": "timescaledb" },
      "targets": [
        {
          "rawSql": "SELECT geo_country AS country, SUM(viewer_count) AS viewers FROM stream_metrics WHERE $__timeFilter(time) AND geo_country IS NOT NULL GROUP BY geo_country ORDER BY viewers DESC LIMIT 50",
          "format": "table"
        }
      ],
      "options": {
        "view": { "id": "zero", "lat": 0, "lon": 0, "zoom": 1 },
        "controls": { "showZoom": true, "mouseWheelZoom": true },
        "layers": [
          {
            "type": "markers",
            "name": "Viewers",
            "config": {
              "style": { "color": { "fixed": "dark-blue" }, "opacity": 0.8, "size": { "fixed": 5 } }
            }
          }
        ]
      },
      "gridPos": { "h": 8, "w": 18, "x": 6, "y": 12 }
    }
  ]
}
