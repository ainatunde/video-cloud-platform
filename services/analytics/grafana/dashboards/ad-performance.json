{
  "uid": "ad-performance",
  "title": "Ad Performance",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "stream_id",
        "label": "Stream",
        "type": "query",
        "datasource": { "type": "postgres", "uid": "timescaledb" },
        "query": "SELECT DISTINCT stream_id FROM ad_analytics ORDER BY 1",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "allValue": ".*",
        "current": {}
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Impression Count",
      "type": "stat",
      "datasource": { "type": "postgres", "uid": "timescaledb" },
      "targets": [
        {
          "rawSql": "SELECT COUNT(*) AS value FROM ad_analytics WHERE $__timeFilter(time) AND event_type = 'impression'",
          "format": "table"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "blue" }
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 }
    },
    {
      "id": 2,
      "title": "Click Count",
      "type": "stat",
      "datasource": { "type": "postgres", "uid": "timescaledb" },
      "targets": [
        {
          "rawSql": "SELECT COUNT(*) AS value FROM ad_analytics WHERE $__timeFilter(time) AND event_type = 'click'",
          "format": "table"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "green" }
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 }
    },
    {
      "id": 3,
      "title": "Completion Rate",
      "type": "gauge",
      "datasource": { "type": "postgres", "uid": "timescaledb" },
      "targets": [
        {
          "rawSql": "SELECT ROUND(100.0 * COUNT(*) FILTER (WHERE event_type = 'complete') / NULLIF(COUNT(*) FILTER (WHERE event_type = 'impression'), 0), 2) AS value FROM ad_analytics WHERE $__timeFilter(time)",
          "format": "table"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showThresholdMarkers": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "green", "value": 75 }
            ]
          }
        }
      },
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 4 }
    },
    {
      "id": 4,
      "title": "Click-Through Rate",
      "type": "gauge",
      "datasource": { "type": "postgres", "uid": "timescaledb" },
      "targets": [
        {
          "rawSql": "SELECT ROUND(100.0 * COUNT(*) FILTER (WHERE event_type = 'click') / NULLIF(COUNT(*) FILTER (WHERE event_type = 'impression'), 0), 2) AS value FROM ad_analytics WHERE $__timeFilter(time)",
          "format": "table"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showThresholdMarkers": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "green", "value": 3 }
            ]
          }
        }
      },
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 4 }
    },
    {
      "id": 5,
      "title": "Revenue by Ad Server",
      "type": "barchart",
      "datasource": { "type": "postgres", "uid": "timescaledb" },
      "targets": [
        {
          "rawSql": "SELECT COALESCE(ad_server, 'unknown') AS ad_server, COUNT(*) FILTER (WHERE event_type = 'impression') AS impressions FROM ad_analytics WHERE $__timeFilter(time) GROUP BY ad_server ORDER BY impressions DESC",
          "format": "table"
        }
      ],
      "options": {
        "orientation": "vertical",
        "barRadius": 0.0,
        "groupWidth": 0.7,
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 }
    },
    {
      "id": 6,
      "title": "Fill Rate Over Time",
      "type": "timeseries",
      "datasource": { "type": "postgres", "uid": "timescaledb" },
      "targets": [
        {
          "rawSql": "SELECT time_bucket('10m', time) AS time, ROUND(100.0 * COUNT(*) FILTER (WHERE event_type = 'complete') / NULLIF(COUNT(*) FILTER (WHERE event_type = 'impression'), 0), 2) AS fill_rate FROM ad_analytics WHERE $__timeFilter(time) GROUP BY 1 ORDER BY 1",
          "format": "time_series"
        }
      ],
      "options": {
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "color": { "mode": "palette-classic" }
        }
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 12 }
    }
  ]
}
