{
  "uid": "ai-content-analysis",
  "title": "AI Content Analysis",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "stream_id",
        "label": "Stream",
        "type": "query",
        "datasource": { "type": "postgres", "uid": "timescaledb" },
        "query": "SELECT DISTINCT stream_id FROM content_analysis ORDER BY 1",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "allValue": ".*",
        "current": {}
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Detections per Second",
      "type": "timeseries",
      "datasource": { "type": "postgres", "uid": "timescaledb" },
      "targets": [
        {
          "rawSql": "SELECT time_bucket('10s', time) AS time, COUNT(*) AS detections FROM content_analysis WHERE $__timeFilter(time) GROUP BY 1 ORDER BY 1",
          "format": "time_series"
        }
      ],
      "options": {
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" }
        }
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 0 }
    },
    {
      "id": 2,
      "title": "Top Detected Objects",
      "type": "barchart",
      "datasource": { "type": "postgres", "uid": "timescaledb" },
      "targets": [
        {
          "rawSql": "SELECT obj->>'label' AS object_label, COUNT(*) AS count FROM content_analysis, jsonb_array_elements(objects) AS obj WHERE $__timeFilter(time) GROUP BY 1 ORDER BY 2 DESC LIMIT 20",
          "format": "table"
        }
      ],
      "options": {
        "orientation": "horizontal",
        "barRadius": 0.0,
        "groupWidth": 0.7,
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" }
        }
      },
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 8 }
    },
    {
      "id": 3,
      "title": "Content Categories Distribution",
      "type": "piechart",
      "datasource": { "type": "postgres", "uid": "timescaledb" },
      "targets": [
        {
          "rawSql": "SELECT COALESCE(iab_tier1, 'Unknown') AS category, COUNT(*) AS count FROM content_analysis WHERE $__timeFilter(time) GROUP BY 1 ORDER BY 2 DESC",
          "format": "table"
        }
      ],
      "options": {
        "pieType": "pie",
        "displayLabels": ["percent"],
        "legend": { "displayMode": "table", "placement": "right" }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" }
        }
      },
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 8 }
    },
    {
      "id": 4,
      "title": "Scene Changes Over Time",
      "type": "timeseries",
      "datasource": { "type": "postgres", "uid": "timescaledb" },
      "targets": [
        {
          "rawSql": "SELECT time_bucket('1m', time) AS time, stream_id, COUNT(DISTINCT scene_id) AS scene_changes FROM content_analysis WHERE $__timeFilter(time) GROUP BY 1, 2 ORDER BY 1",
          "format": "time_series"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" }
        }
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 18 }
    },
    {
      "id": 5,
      "title": "Avg Detection Confidence",
      "type": "gauge",
      "datasource": { "type": "postgres", "uid": "timescaledb" },
      "targets": [
        {
          "rawSql": "SELECT AVG(confidence) AS value FROM content_analysis WHERE $__timeFilter(time)",
          "format": "table"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showThresholdMarkers": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.6 },
              { "color": "green", "value": 0.8 }
            ]
          }
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 26 }
    }
  ]
}
