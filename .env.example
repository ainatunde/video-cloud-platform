# ─────────────────────────────────────────────────────────────────────────────
# Video Cloud Distribution Platform — Environment Variables
# Copy this file to .env and fill in real values before running in production.
# NEVER commit the .env file to source control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ─────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=changeme
TIMESCALE_PASSWORD=changeme
DATABASE_URL=postgresql://postgres:changeme@postgres:5432/platform

# ── Authentication ───────────────────────────────────────────────────────────
JWT_SECRET=changeme                      # Replace with 64-char random string in production

# ── Grafana ──────────────────────────────────────────────────────────────────
GRAFANA_PASSWORD=changeme

# ── SRS Ingest Server ────────────────────────────────────────────────────────
SRS_HTTP_API_AUTH=                       # Optional Bearer token for SRS HTTP API

# ── AI / YOLO ────────────────────────────────────────────────────────────────
YOLO_MODEL=yolov8n.pt                    # yolov8n.pt | yolov8s.pt | yolov8m.pt
GPU_ENABLED=false                        # Set to true when NVIDIA GPU available

# ── FFmpeg Transcoding ───────────────────────────────────────────────────────
HARDWARE_ACCEL=false                     # nvenc | vaapi | qsv | false (CPU)
ABR_PROFILES=360p,480p,720p,1080p        # Comma-separated list of output profiles

# ── HLS / DASH Packaging ────────────────────────────────────────────────────
HLS_SEGMENT_DURATION=6                  # Seconds per HLS segment
BASE_URL=http://localhost               # Public base URL for manifest generation

# ── SCTE-35 Ad Insertion ────────────────────────────────────────────────────
SCTE35_SPLICE_DURATION=30               # Default splice duration in seconds

# ── Ad Server ────────────────────────────────────────────────────────────────
NODE_ENV=production                     # production | development
AD_SERVER_URL=                          # External ad server endpoint (optional)
VAST_URL=                               # VAST tag URL (optional)

# ── Service Ports ────────────────────────────────────────────────────────────
RTMP_PORT=1935
SRT_PORT=8890
HTTP_API_PORT=8080
AD_SERVER_PORT=3000
GRAFANA_PORT=3001
DASHBOARD_PORT=3002
