# ─────────────────────────────────────────────────────────────────────────────
# Video Cloud Distribution Platform — .gitignore
# ─────────────────────────────────────────────────────────────────────────────

# ── Environment / Secrets ────────────────────────────────────────────────────
.env
.env.local
.env.*.local

# ── Node.js ──────────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
dist/
build/
.next/
out/

# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
.Python
venv/
.venv/
env/
ENV/
*.egg-info/
.eggs/
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
coverage/
.coverage
*.cover

# ── YOLO / ML Models ─────────────────────────────────────────────────────────
*.pt
*.pth
*.onnx
*.engine
models/
!models/.gitkeep

# ── Media / Video Files ──────────────────────────────────────────────────────
videos/
*.mp4
*.ts
*.m3u8
*.m4s
*.mpd
*.flv
*.mkv
*.avi
*.mov
*.webm
*.aac
*.mp3

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/
*.out

# ── OS / IDE ─────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
.vscode/
.idea/
*.swp
*.swo

# ── Docker ───────────────────────────────────────────────────────────────────
# (keep docker-compose*.yml tracked; ignore override secrets)
docker-compose.override.yml

# ── Kubernetes secrets ───────────────────────────────────────────────────────
kubernetes/secrets/
*.kubeconfig

# ── TLS / Certificates ───────────────────────────────────────────────────────
config/nginx/ssl/*.key
config/nginx/ssl/*.crt
config/nginx/ssl/*.pem

# ── Temporary / Generated ────────────────────────────────────────────────────
tmp/
temp/
*.tmp
*.bak
*.orig
